#pragma kernel TectonicsGenerator

RWTexture3D<float4> TectonicLookupTexture;

const float FLT_MAX = 10000000;

int amountOfPlates;

float4 tectonicPoints[1024];
float4 tectonicColours[25];

int textureSize;
float planetRadius;

struct TectonicPlate
{
    float4 colour;
};

TectonicPlate tectonicPlates[25];


[numthreads(8,8,8)]
void TectonicsGenerator(uint3 id : SV_DispatchThreadID)
{
    float3 worldPos = (id / float(textureSize - 1.0) - 0.5f) * planetRadius;
    
    float halfRadius = planetRadius / 2;
    float maxD = length(float3(halfRadius, halfRadius, halfRadius));
    
    float pixelValue = length(worldPos) / (maxD + 1) - 0.5f;
    
    // pixelValue == 0 is the surface of the sphere
    if (pixelValue > -0.01f && pixelValue < 0.01f)
    { // is a surface point
        int closestPointIndex = -1;
        float closestDistance = 1000000;
        
        for (int i = 0; i < amountOfPlates; i++)
        {
            
            if (distance(worldPos, tectonicPoints[i].xyz) < closestDistance)
            {
                closestPointIndex = i;
                closestDistance = distance(worldPos, tectonicPoints[i].xyz);

            }
        }
        
        TectonicLookupTexture[id] = tectonicColours[closestPointIndex];
        
    
    
        for (int i = 0; i < amountOfPlates; i++)
        {
            if (distance(worldPos, tectonicPoints[i].xyz) < 0.25f)
            {
                TectonicLookupTexture[id] = tectonicColours[i];
            }
        }
        
    }
        
        
        
}